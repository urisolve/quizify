# App
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:2030
APP_NAME=HALO - AI ENGINEering Education
SESSION_SECRET=halo_dev_secret_key
LOG_LEVEL=dev

# Database
DB_HOST=mysql
DB_PORT=3306
DB_NAME=halo_db
DB_USER=halo_user
DB_PASSWORD=halo_pass

# MySQL / MariaDB
MYSQL_ROOT_PASSWORD=halo_root_pass
MYSQL_DATABASE=halo_db
MYSQL_USER=halo_user
MYSQL_PASSWORD=halo_pass

# App settings
BOTH_MODELS_PROB=0.5

# Feature flags
ENABLE_ANALYTICS=false
ENABLE_CHATBOT=false