<!-- views/pages/contributors.hbs -->
<div class="container-fluid">
  <div class="row g-4">

    <!-- HERO -->
    <div class="col-12">
      <section class="card border-0 halo-hero-card overflow-hidden">
        <div class="card-body p-4 p-lg-5">
          <span class="badge rounded-pill bg-primary-subtle text-primary mb-3">HALO Team</span>
          <h1 class="display-6 fw-semibold mb-3">Contributors & Collaborators</h1>
          <p class="fs-4 text-dark mb-0 halo-lead" style="text-align: justify;">
            Meet the people who helped shape the HALO and U=RIsolve ecosystem over the years,
            from project coordination and academic guidance to development, experimentation and
            implementation of new features and learning tools.
          </p>
        </div>
      </section>
    </div>

    <!-- COORDINATORS -->
    <div class="col-12">
      <section class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="halo-section-icon bg-light-primary text-primary">
              <i class="ti ti-users"></i>
            </span>
            <div>
              <h2 class="card-title fw-semibold mb-1">Coordinators</h2>
              <p class="mb-0 text-muted">
                Project leadership and strategic direction.
              </p>
            </div>
          </div>

          <div class="row g-4">
            {{#each coordinators}}
              <div class="col-12 col-md-6">
                <div class="card h-100 border-0 bg-light-subtle shadow-sm rounded-4">
                  <div class="card-body p-4">
                    <div class="d-flex flex-column flex-sm-row align-items-center align-items-sm-start gap-4">
                      <div class="text-center flex-shrink-0">
                        <img
                          src="{{this.photoUrl}}"
                          alt="{{this.name}}"
                          class="img-fluid rounded-circle border p-2"
                          style="width: 108px; height: 108px; object-fit: contain; background-color: #f8f9fa;"
                        >
                      </div>

                      <div class="text-center text-sm-start w-100">
                        <h4 class="fw-semibold mb-2">{{this.name}}</h4>
                        <p class="text-muted mb-2">{{this.role}}</p>

                        {{#if this.email}}
                          <a href="mailto:{{this.email}}" class="text-decoration-none">
                            <i class="ti ti-mail me-1"></i>{{this.email}}
                          </a>
                        {{/if}}
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
    </div>

    <!-- PROFESSORS -->
    <div class="col-12">
      <section class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="halo-section-icon bg-light-info text-info">
              <i class="ti ti-school"></i>
            </span>
            <div>
              <h2 class="card-title fw-semibold mb-1">Professors</h2>
              <p class="mb-0 text-muted">
                Academic collaboration, supervision and domain expertise.
              </p>
            </div>
          </div>

          <div class="row g-4">
            {{#each professors}}
              <div class="col-12 col-md-6 col-xl-4">
                <div class="card h-100 border shadow-sm rounded-4">
                  <div class="card-body p-4">
                    <div class="d-flex align-items-center gap-3 mb-3">
                      <img
                        src="{{this.photoUrl}}"
                        alt="{{this.name}}"
                        class="img-fluid rounded-circle border p-1 flex-shrink-0"
                        style="width: 72px; height: 72px; object-fit: contain; background-color: #f8f9fa;"
                      >

                      <div>
                        <h5 class="fw-semibold mb-1">{{this.name}}</h5>
                        <p class="text-muted mb-0">{{this.role}}</p>
                      </div>
                    </div>

                    {{#if this.email}}
                      <p class="mb-0">
                        <a href="mailto:{{this.email}}" class="text-decoration-none">
                          <i class="ti ti-mail me-1"></i>{{this.email}}
                        </a>
                      </p>
                    {{/if}}
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
    </div>

    <!-- CONTRIBUTORS -->
    <div class="col-12">
      <section class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="halo-section-icon bg-light-warning text-warning">
              <i class="ti ti-code"></i>
            </span>
            <div>
              <h2 class="card-title fw-semibold mb-1">Contributors</h2>
              <p class="mb-0 text-muted">
                Development work, project implementations and academic outputs.
              </p>
            </div>
          </div>

          <div class="row g-4">
            {{#each contributors}}
              <div class="col-12">
                <div class="card border rounded-4 shadow-sm overflow-hidden">
                  <div class="card-body p-4">
                    <div class="row g-4">
                      <div class="col-12 col-lg-3">
                        <div class="text-center text-lg-start">
                          <img
                            src="{{this.photoUrl}}"
                            alt="{{this.name}}"
                            class="img-fluid rounded-circle border p-2 mb-3"
                            style="width: 112px; height: 112px; object-fit: contain; background-color: #f8f9fa;"
                          >

                          <h4 class="fw-semibold mb-1">{{this.name}}</h4>
                          <p class="text-muted mb-2">{{this.role}}</p>

                          {{#if this.email}}
                            <p class="mb-0">
                              <a href="mailto:{{this.email}}" class="text-decoration-none">
                                <i class="ti ti-mail me-1"></i>{{this.email}}
                              </a>
                            </p>
                          {{/if}}
                        </div>
                      </div>

                      <div class="col-12 col-lg-9">
                        {{#if this.contributions.length}}
                          <div class="d-flex align-items-center gap-2 mb-3">
                            <i class="ti ti-history text-primary"></i>
                            <h5 class="fw-semibold mb-0">Contribution History</h5>
                          </div>

                          <div class="d-grid gap-3">
                            {{#each this.contributions}}
                              <a href="{{this.fileUrl}}" target="_blank" class="text-decoration-none">
                                <div class="card border-0 bg-light-subtle shadow-sm rounded-4 h-100">
                                  <div class="card-body p-4">
                                    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-start gap-3">
                                      
                                      <div class="pe-lg-4">
                                        <div class="d-flex align-items-center gap-2 mb-2">
                                          <span class="badge rounded-pill text-bg-info">{{this.institution}}</span>
                                        </div>

                                        <h5 class="fw-semibold text-dark mb-2">{{this.title}}</h5>

                                        <p class="text-muted mb-0" style="text-align: justify;">
                                          {{this.description}}
                                        </p>
                                      </div>

                                      <div class="text-lg-end flex-shrink-0">
                                        <div class="small text-muted mb-2">{{this.date}}</div>
                                        <span class="btn btn-sm btn-outline-primary">
                                          <i class="ti ti-file-download me-1"></i>Open file
                                        </span>
                                      </div>

                                    </div>
                                  </div>
                                </div>
                              </a>
                            {{/each}}
                          </div>

                        {{else}}
                          <div class="card border-0 bg-light-subtle rounded-4">
                            <div class="card-body p-4">
                              <p class="text-muted mb-0">No contribution records available yet.</p>
                            </div>
                          </div>
                        {{/if}}
                      </div>

                    </div>
                  </div>
                </div>
              </div>
            {{/each}}
          </div>
        </div>
      </section>
    </div>

  </div>
</div>