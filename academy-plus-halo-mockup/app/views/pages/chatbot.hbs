<div class="container-fluid">
  <div class="row g-4">

    <!-- HERO -->
    <div class="col-12">
      <section class="card border-0 halo-hero-card overflow-hidden">
        <div class="card-body p-4 p-lg-5">
          <span class="badge rounded-pill bg-primary-subtle text-primary mb-3">HALO Assistant</span>
          <h1 class="display-6 fw-semibold mb-3">Trigger HALO</h1>
          <p class="fs-4 text-dark mb-0 halo-lead" style="text-align: justify;">
            Interact with the HALO system through a clean prompt-based interface. Use the main prompt area for
            regular interaction, and expand the advanced options only when you need to define system instructions,
            prior messages or a specific model.
          </p>
        </div>
      </section>
    </div>

    <!-- CHAT -->
    <div class="col-12">
      <section class="card border-0 shadow-sm">
        <div class="card-body p-4 p-lg-5">
          <div class="d-flex align-items-center gap-3 mb-4">
            <span class="halo-section-icon bg-light-primary text-primary">
              <i class="ti ti-message-chatbot"></i>
            </span>
            <div>
              <h2 class="card-title fw-semibold mb-1">Prompt → Response</h2>
              <p class="mb-0 text-muted">
                A simple interface for interacting with HALO.
              </p>
            </div>
          </div>

          <div class="row g-4">
            <div class="col-12 col-xl-5">
              <div class="card border rounded-4 shadow-sm h-100">
                <div class="card-body p-4">
                  <div class="mb-4">
                    <label for="promptInput" class="form-label fw-semibold">Prompt</label>
                    <textarea
                      id="promptInput"
                      class="form-control"
                      rows="12"
                      placeholder="Write a prompt for HALO..."
                    >Explain what nodal analysis is in simple terms.</textarea>
                  </div>

                  <div class="d-flex flex-wrap gap-3 mb-3">
                    <button
                      id="sendPromptBtn"
                      class="btn btn-primary px-4 py-2 d-inline-flex align-items-center gap-2"
                      type="button"
                    >
                      <i class="ti ti-send"></i>
                      <span>Send</span>
                    </button>

                    <button
                      id="clearResponseBtn"
                      class="btn btn-outline-secondary px-4 py-2 d-inline-flex align-items-center gap-2"
                      type="button"
                    >
                      <i class="ti ti-eraser"></i>
                      <span>Clear</span>
                    </button>
                  </div>

                  <button
                    class="btn btn-link px-0 text-decoration-none d-inline-flex align-items-center gap-2"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#advancedOptions"
                    aria-expanded="false"
                    aria-controls="advancedOptions"
                  >
                    <i class="ti ti-adjustments-horizontal"></i>
                    <span>Advanced options</span>
                  </button>

                  <div class="collapse mt-3" id="advancedOptions">
                    <div class="card border-0 bg-light-subtle rounded-4">
                      <div class="card-body p-4">
                        <div class="mb-3">
                          <label for="modelSelect" class="form-label fw-semibold">Model</label>
                          <select id="modelSelect" class="form-select">
                            <option value="">Default model</option>
                            <option value="base">base</option>
                            <option value="nvm-conceptual:latest">nvm-conceptual:latest</option>
                            <option value="nvm-procedural:latest">nvm-procedural:latest</option>
                            <option value="nvm-application:latest">nvm-application:latest</option>
                            <option value="nvm-evaluation:latest">nvm-evaluation:latest</option>
                            <option value="nvm-advanced:latest">nvm-advanced:latest</option>
                            <option value="nvm-full-v2:latest">nvm-full-v2:latest</option>
                          </select>
                        </div>

                        <div class="mb-3">
                          <label for="systemInput" class="form-label fw-semibold">System</label>
                          <textarea
                            id="systemInput"
                            class="form-control"
                            rows="4"
                            placeholder="Optional system instruction..."
                          >You are a helpful Engineering Education assistant.</textarea>
                        </div>

                        <div class="mb-0">
                          <label for="messagesInput" class="form-label fw-semibold">Messages (JSON array)</label>
                          <textarea
                            id="messagesInput"
                            class="form-control font-monospace"
                            rows="6"
                            placeholder="[]"
                          >[]</textarea>
                        </div>
                      </div>
                    </div>
                  </div>

                </div>
              </div>
            </div>

            <div class="col-12 col-xl-7">
              <div class="card border rounded-4 shadow-sm h-100">
                <div class="card-body p-4 d-flex flex-column">
                  <div class="mb-3">
                    <label class="form-label fw-semibold">Response</label>
                    <div
                      id="responseBox"
                      class="form-control bg-light"
                      style="min-height: 520px; white-space: pre-wrap; text-align: justify;"
                    >Response will appear here...</div>
                  </div>

                  <div id="statusBox" class="small text-muted mt-auto"></div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </section>
    </div>

  </div>
</div>

<script src="/js/pages/chatbot.js"></script>